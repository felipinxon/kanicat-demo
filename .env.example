# Clave de OpenAI para el asistente Kani (backend /api/chat).
# En el servidor se reutiliza la key existente (app panoramax) como variable de
# entorno; NO se commitea. Sin ella, el chat cae a un modo demo local (fallback).
OPENAI_API_KEY=

# Modelo del asistente (por defecto gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini
