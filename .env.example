# Clave de Anthropic para el asistente Kani (backend /api/chat).
# En el servidor se inyecta como variable de entorno en Coolify (NO se commitea).
# Si no se define, el chat cae automáticamente a un modo demo local (fallback).
ANTHROPIC_API_KEY=

# Modelo del asistente. Por defecto claude-haiku-4-5 (rápido para chat en vivo).
# Usa claude-opus-4-8 para máxima calidad.
KANI_MODEL=claude-haiku-4-5
